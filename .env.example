# Microsoft Graph (Work IQ) - Register an app at https://entra.microsoft.com
# Permissions needed (delegated): Mail.Read, Calendars.Read, Chat.Read, User.Read
MS_CLIENT_ID=your-app-client-id-here
MS_TENANT_ID=your-tenant-id-or-common

# GitHub Models (included with Copilot Business)
# Get your token from https://github.com/settings/tokens (with "models" scope)
GITHUB_TOKEN=your-github-pat-here

# Optional: Choose the model (default: gpt-4o)
GITHUB_MODEL=gpt-4o
